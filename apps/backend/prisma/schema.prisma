generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  client
}

enum UserStatus {
  pending
  approved
  rejected
}

enum TerminalKitState {
  initiated
  active
  deactivated_temp
  deactivated_perm
}

enum ActionType {
  activate
  deactivate_temp
  deactivate_perm
}

enum ActionStatus {
  pending_admin
  pending_provider
  completed
  failed
}

enum ProviderRequestStatus {
  pending
  partial_success
  completed
  failed
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  login          String          @unique
  passwordHash   String          @map("password_hash")
  role           UserRole
  status         UserStatus
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  clientRequests ClientRequest[]

  @@map("users")
}

model TerminalKit {
  id           String           @id @default(uuid())
  terminalKit  String     @unique @map("terminal_kit")
  currentState TerminalKitState? @map("current_state")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  actions      TerminalKitAction[]

  @@map("terminal_kits")
}
model ClientRequest {
  id                 String              @id @default(uuid())
  userId             String              @map("user_id")
  comment            String
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  user               User                @relation(fields: [userId], references: [id])
  terminalKitActions TerminalKitAction[]

  @@map("client_requests")
}

model TerminalKitAction {
  id                String            @id @default(uuid())
  actionType        ActionType        @map("action_type")
  status            ActionStatus
  previousState     TerminalKitState? @map("previous_state")
  resultingState    TerminalKitState? @map("resulting_state")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  // This column stores the unique TerminalKit.terminalKit value, not the internal TerminalKit.id.
  terminalKitId     String            @map("terminal_kit_id")
  clientRequestId   String            @map("client_request_id")
  providerRequestId String?           @map("provider_request_id")
  terminalKit       TerminalKit       @relation(fields: [terminalKitId], references: [terminalKit])
  clientRequest     ClientRequest     @relation(fields: [clientRequestId], references: [id])
  providerRequest   ProviderRequest?  @relation(fields: [providerRequestId], references: [id])

  @@index([status], map: "idx_terminal_kit_actions_status")
  @@index([providerRequestId], map: "idx_terminal_kit_actions_provider_request_id")
  @@map("terminal_kit_actions")
}

model ProviderRequest {
  id                 String                @id @default(uuid())
  externalId         String                @map("external_id")
  comment            String                @default("")
  status             ProviderRequestStatus
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  terminalKitActions TerminalKitAction[]

  @@map("provider_requests")
}
